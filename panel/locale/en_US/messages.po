msgstr "The panel name. Customizable from config.php."

msgid "tour_maintenance"
msgstr "Enable or disable site maintenance mode."

msgid "tour_presets"
msgstr "Quick deploy presets: full deploy, cache or compilation."

msgid "tour_lang"
msgstr "Change the interface language."

